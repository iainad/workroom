#!/usr/bin/env bash
set -euo pipefail

# Run by workroom as a setup script. workroom executes us inside the new workroom
# directory and exposes WORKROOM_NAME, WORKROOM_PATH and WORKROOM_ROOT_PATH, so we
# take no arguments. See https://github.com/joelmoss/workroom#environment-variables.

# Returns 0 iff both paths exist and refer to the same underlying file (same
# device + inode). Catches the case where one path is a symlink to the other.
same_file() {
  local a="$1" b="$2"
  [[ -e "$a" && -e "$b" ]] || return 1

  local fmt='%d:%i'
  local sa sb
  if stat --version >/dev/null 2>&1; then
    sa=$(stat -Lc "$fmt" "$a")
    sb=$(stat -Lc "$fmt" "$b")
  else
    sa=$(stat -Lf "$fmt" "$a")
    sb=$(stat -Lf "$fmt" "$b")
  fi

  [[ "$sa" == "$sb" ]]
}

copy_claude_local_settings() {
  local src="${WORKROOM_ROOT_PATH}/.claude/settings.local.json"
  local dest="${WORKROOM_PATH}/.claude/settings.local.json"

  if [[ -f "$src" ]]; then
    cp "$src" "$dest"
    echo "Copied Claude local settings to workspace."
  fi
}

main() {
  local var
  for var in WORKROOM_NAME WORKROOM_PATH WORKROOM_ROOT_PATH; do
    if [[ -z "${!var:-}" ]]; then
      echo "ERROR: $var is not set. This script is meant to be run by workroom." >&2
      echo "See https://github.com/joelmoss/workroom#environment-variables." >&2
      exit 1
    fi
  done

  if same_file "$WORKROOM_ROOT_PATH" "$WORKROOM_PATH"; then
    echo "ERROR: WORKROOM_ROOT_PATH ('$WORKROOM_ROOT_PATH') resolves to the workspace directory. Aborting to avoid clobbering source files." >&2
    exit 1
  fi

  copy_claude_local_settings
}

main "$@"
